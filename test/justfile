# Run IDAPython script integration test
test-script: fixture
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -x "{{ server_bin }}" ]; then
        echo "Server binary not found: {{ server_bin }}"
        echo "Run 'cargo build --release' first"
        exit 1
    fi
    LOCK="{{ test_lock }}"
    if [ -f "$LOCK" ]; then
        pid=$(awk -F= '$1=="pid"{print $2}' "$LOCK" | tr -d '\r')
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            echo "Lock file $LOCK is held by pid $pid; close that server first." >&2
            exit 1
        else
            rm -f "$LOCK"
        fi
    fi
    echo "🧪 Running IDAPython script test..."
    tmp="$(mktemp)"
    # Keep stdin open long enough for open_idb auto-analysis (~10s for raw binaries)
    (cat payloads/script.jsonl; sleep 30) | RUST_LOG="{{ rust_log }}" "{{ server_bin }}" >"$tmp" 2>&1 || true
    cat "$tmp"

    # Verify simple inline script execution (id=3)
    if ! rg -q 'inline_simple_ok function_count=' "$tmp"; then
        echo "❌ Simple inline script output missing"
        rm -f "$tmp"
        exit 1
    fi

    # Verify file-based script execution (id=4)
    if ! rg -q 'total_functions=' "$tmp"; then
        echo "❌ File-based script (fixtures/test_analysis.py) output missing"
        rm -f "$tmp"
        exit 1
    fi

    # Verify complex inline script execution (id=5)
    if ! rg -q 'complex_ok total=' "$tmp"; then
        echo "❌ Complex inline script output missing"
        rm -f "$tmp"
        exit 1
    fi

    # Verify syntax error surfaced as MCP-level error (id=6)
    error_count="$( (rg -o '"isError"\s*:\s*true' "$tmp" || true) | wc -l | tr -d ' ' )"
    if [ "$error_count" != "1" ]; then
        echo "❌ Expected exactly one MCP-level error response, got $error_count"
        rm -f "$tmp"
        exit 1
    fi
    if ! rg -q 'SyntaxError' "$tmp"; then
        echo "❌ SyntaxError details missing for invalid script case"
        rm -f "$tmp"
        exit 1
    fi
    if ! rg -q 'IDAPython script execution failed' "$tmp"; then
        echo "❌ Script failure summary missing for invalid script case"
        rm -f "$tmp"
        exit 1
    fi

    rm -f "$tmp"
    echo "✅ Script test passed"

# Run multi-IDB integration test (router mode)
test-multi: fixture
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -x "{{ server_bin }}" ]; then
        echo "Server binary not found: {{ server_bin }}"
        echo "Run 'cargo build --release' first"
        exit 1
    fi
    echo "🧪 Running multi-IDB integration test..."
    tmp="$(mktemp)"
    # Keep stdin open long enough for two open_idb auto-analyses (~20s for raw binaries)
    (cat payloads/multi.jsonl; sleep 40) | RUST_LOG="{{ rust_log }}" "{{ server_bin }}" serve >"$tmp" 2>&1 || true
    cat "$tmp"
    # Verify two different db_handle values in open_idb responses
    # Note: db_handle appears in escaped JSON as \"db_handle\": \"<hex>\"
    handles="$(grep -o 'db_handle[^,}]*' "$tmp" | grep -oE '[0-9a-f]{16}' | sort -u || true)"
    handle_count="$(echo "$handles" | grep -c . || echo 0)"
    if [ "$handle_count" -lt 2 ]; then
        echo "❌ Expected 2 different db_handle values, got $handle_count"
        rm -f "$tmp"
        exit 1
    fi
    echo "   Found $handle_count unique db_handles"
    # Verify no unexpected errors
    if grep -qE '"isError"\s*:\s*true' "$tmp"; then
        echo "❌ Unexpected error responses found"
        rm -f "$tmp"
        exit 1
    fi
    # Verify close_idb succeeded at least once
    if ! grep -q 'Database closed' "$tmp"; then
        echo "❌ close_idb did not succeed"
        rm -f "$tmp"
        exit 1
    fi
    rm -f "$tmp"
    echo "✅ Multi-IDB test passed"

# Run 3-DB concurrent integration test (router mode)
test-3db:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -x "{{ server_bin }}" ]; then
        echo "Server binary not found: {{ server_bin }}"
        exit 1
    fi
    for f in "{{ PUMPFUN_IDB }}" "{{ RAYDIUM_IDB }}" "{{ JUPITER_IDB }}"; do
        if [ ! -f "$f" ]; then
            echo "Missing fixture: $f"
            exit 1
        fi
    done
    echo "🧪 Running 3-DB concurrent test..."
    SERVER_BIN="{{ server_bin }}" RUST_LOG="{{ rust_log }}" \
        PUMPFUN_IDB="{{ PUMPFUN_IDB }}" \
        RAYDIUM_IDB="{{ RAYDIUM_IDB }}" \
        JUPITER_IDB="{{ JUPITER_IDB }}" \
        ./3db_integration.sh
    echo "✅ 3-DB test passed"

